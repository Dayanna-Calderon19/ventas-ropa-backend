{
  "name": "tienda-backend",
  "version": "1.0.0",
  "description": "Backend - Sistema de Gestión de Ventas de Ropa",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "node src/prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && node src/prisma/seed.js"
  },
  "prisma": {
    "seed": "node src/prisma/seed.js",
    "schema": "src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^5.14.0",
    "@prisma/client": "^5.14.0",
    "@prisma/config": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0",
    "typescript": "^6.0.3"
  }
}
